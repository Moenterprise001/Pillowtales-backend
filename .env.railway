# PillowTales Production Backend Environment Variables
# Copy these to Railway Dashboard → Variables

# Supabase Configuration (REQUIRED)
SUPABASE_URL=https://mgclekcuskkgfnffvpdj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# LLM API Key for Story Generation (REQUIRED)
EMERGENT_LLM_KEY=your_emergent_llm_key_here

# ElevenLabs for Text-to-Speech (REQUIRED)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# CORS - Allow all origins for mobile app
CORS_ORIGINS=*

# Optional: RevenueCat for subscription webhooks
REVENUECAT_SECRET_KEY=placeholder-revenuecat-secret
